# ========================
# 🌐 APP CONFIG
# ========================
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:3000
SERVER_URL=http://localhost:4000

# ========================
# 🗄️ DATABASE (PostgreSQL)
# ========================
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_database_password
DB_NAME=your_database_name

# ========================
# 🔐 AUTH & SECURITY
# ========================
JWT_SECRET=your_super_secret_jwt_key_please_change
JWT_REFRESH_SECRET=your_super_secret_refresh_key_please_change
EMAIL_VERIFICATION_SECRET=your_email_verification_secret
PASSWORD_RESET_SECRET=your_password_reset_secret
SALT=10

# ========================
# 📧 EMAIL (SMTP)
# ========================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password
ADMIN_EMAIL=admin@yourcompany.com

# ========================
# 🧵 REDIS (BullMQ / Cache)
# ========================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# ========================
# 📄 PAGINATION
# ========================
LIMIT_PAGE=10

# ========================
# ☁️  CLOUDINARY (File Upload)
# ========================
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
